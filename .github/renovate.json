{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>jacaudi/renovate-config:base",
    "github>jacaudi/renovate-config:go",
    "github>jacaudi/renovate-config:kubernetes",
    "github>jacaudi/renovate-config:helm",
    "github>jacaudi/renovate-config:automerge"
  ],
  "semanticCommitType": "fix",
  "semanticCommitScope": "deps",
  "commitMessagePrefix": "fix(deps):",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Makefile controller-tools pin",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["CONTROLLER_TOOLS_VERSION \\?= (?<currentValue>v[0-9.]+)"],
      "depNameTemplate": "sigs.k8s.io/controller-tools",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "description": "Makefile golangci-lint pin",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["GOLANGCI_LINT_VERSION \\?= (?<currentValue>v[0-9.]+)"],
      "depNameTemplate": "github.com/golangci/golangci-lint/v2",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "description": "Makefile kustomize pin",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": ["KUSTOMIZE_VERSION \\?= (?<currentValue>v[0-9.]+)"],
      "depNameTemplate": "sigs.k8s.io/kustomize/kustomize/v5",
      "datasourceTemplate": "go"
    }
  ]
}
